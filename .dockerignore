*.obj
*.a
*.so
*.dylib
*.dSYM/
build.baremetal/
vekterm
kernel.img
vekterm.img
out/
/tests/test_protocol
/tests/test_frame
/tests/test_coord

# Local cruft
*.bin
.DS_Store
*.swp
*~
.venv/
__pycache__/
